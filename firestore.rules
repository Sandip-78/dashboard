rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is signed in
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to get the user's role from their user document
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Super admins have full access
    function isSuperAdmin() {
      return isAuthenticated() && getUserRole() == 'super_admin';
    }
    
    // Admins (or super admins) have access to products and orders
    function isAdmin() {
      return isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'super_admin');
    }

    // --- RULES ---

    match /users/{userId} {
      // A user can read their own document (to check their role on login)
      // Super admins can read and write all user documents
      allow read: if isSuperAdmin() || request.auth.uid == userId;
      allow write: if isSuperAdmin();
    }

    match /products/{productId} {
      // Admins and Super Admins can manage products
      allow read, write: if isAdmin();
    }

    match /orders/{orderId} {
      // Admins and Super Admins can manage orders
      allow read, write: if isAdmin();
    }
  }
}
